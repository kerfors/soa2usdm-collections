 "annotations": [
  {
   "annotation_marker": "a",
   "annotation_type": "footnote",
   "annotation_text": "From Visit 3 onwards, visits will take place on the first day of each 4-week visit period, relative to the date of the first olaparib dose (if the patient has not progressed and is still on treatment). Where the visit does not coincide with tumour assessment visits, these safety visits will only be for laboratory and pregnancy testing and recording of ECOG status, AEs and concomitant medication including transfusions. Where these visits coincide with tumour assessments, the assessment visit schedule will be performed",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 1,
     "column_position": 5
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 2,
     "column_position": 4
    }
   ]
  },
  {
   "annotation_marker": "b",
   "annotation_type": "footnote",
   "annotation_text": "If assessed within 7 days before first dose and meets the stated eligibility criteria (if applicable), it does not need to be repeated on Day 1 of study treatment unless Investigator believes that it is likely to have changed significantly.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 4,
     "column_position": 2
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 5,
     "column_position": 2
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 7,
     "column_position": 2
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 8,
     "column_position": 2
    }
   ]
  },
  {
   "annotation_marker": "c",
   "annotation_type": "footnote",
   "annotation_text": "To be additionally performed if clinically indicated at any other time.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 4
    },
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 5
    },
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 8
    }
   ]
  },
  {
   "annotation_marker": "d",
   "annotation_type": "footnote",
   "annotation_text": "All samples should be taken prior to first dose. Coagulation test should be performed if clinically indicated. For a list of all required laboratory tests please refer to Section 5.2.1.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 7
    }
   ]
  },
  {
   "annotation_marker": "e",
   "annotation_type": "footnote",
   "annotation_text": "Pregnancy tests on blood or urine samples will be performed for women of childbearing potential within 28 days prior to the start of study treatment, on Day 1 of the study prior to commencing treatment, at the time points shown in Table 2 during study treatment and at the 30-day follow-up visit. If results are positive the patient is ineligible/must be discontinued from study treatment immediately.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 9
    }
   ]
  },
  {
   "annotation_marker": "f",
   "annotation_type": "footnote",
   "annotation_text": "Visit 4 onwards: Subsequent tumour assessments will be conducted every 8 weeks (±7 days) for the first 12 months and then every 12 weeks (± 7 days) until documented disease progression.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 10
    }
   ]
  },
  {
   "annotation_marker": "g",
   "annotation_type": "footnote",
   "annotation_text": "Unless patient was tested at Myriad as part of screening. All patients are required to provide a 9 ml blood sample for confirmation of gBRCA status. Please refer to the laboratory manual for further details regarding blood sample collection, shipping and storage.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 12
    }
   ]
  },
  {
   "annotation_marker": "h",
   "annotation_type": "footnote",
   "annotation_text": "All ongoing AEs/SAEs and any new AEs/SAEs identified during the 30 calendar days follow-up period after last dose of study medication must be followed to resolution.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 13
    }
   ]
  },
  {
   "annotation_marker": "j",
   "annotation_type": "footnote",
   "annotation_text": "+/- 2 days visit window allowed for the dispensing. Sufficient study treatment should be dispensed for at least each treatment period plus overage; however, additional treatment can be dispensed to patients to last longer if required.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 16,
     "column_position": 3
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 16,
     "column_position": 4
    }
   ]
  },
  {
   "annotation_marker": "k",
   "annotation_type": "footnote",
   "annotation_text": "Start date of the first anticancer treatments (including, but not limited to, chemotherapy and targeted agents), following discontinuation from study treatment must be recorded.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 17
    }
   ]
  },
  {
   "annotation_marker": "l",
   "annotation_type": "footnote",
   "annotation_text": "Patient will be followed (can be by phone or email) regularly until start of subsequent therapy; survival will be followed at approximately 12 weekly intervals thereafter.",
   "marker_locations": [
