    {
      "annotation_id": "annot-006",
      "table_id": "table-003",
      "annotation_marker": "6",
      "annotation_type": "footnote",
      "annotation_text": "Footnote not printed in the source (Table 9 prints only footnotes 1-3). Table 9 is the Extended-Visit-Cycle variant of the Main Study, so this most likely corresponds to Table 7 (Main Study) footnote 12: \"If dose interruption or modification is required at any point on study because of hematologic toxicity, weekly blood draws for CBC will be monitored until the adverse event resolves, and to ensure safety of the new dose, weekly blood draws for CBC will be also be required for an additional 4 weeks after the adverse event has been resolved to the specified levels, after which monitoring every 4 weeks may resume.\"",
      "annotation_scope": "activity",
      "referenced_elements": {
        "property_ids": [],
