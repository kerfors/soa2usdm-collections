        }
      ]
    },
    {
      "annotation_id": "annot-007",
      "table_id": "table-003",
      "annotation_marker": "7",
      "annotation_type": "footnote",
      "annotation_text": "Footnote not printed in the source (Table 9 prints only footnotes 1-3). Table 9 is the Extended-Visit-Cycle variant of the Main Study, so this most likely corresponds to Table 7 (Main Study) footnote 13: \"CA-125 levels must be normal at screening or > 90% decrease as compared with baseline prior to last platinum-based chemotherapy course. Abnormal CA-125 levels during study do not represent disease progression; however, they may prompt imaging if clinically indicated. CA-125 sample within 72 hours of dose on Cycle 1/Day 1.\"",
      "annotation_scope": "activity",
      "referenced_elements": {
        "property_ids": [],
        "column_ids": [],
        "activity_ids": [
          "act-008"
        ],
        "cell_references": []
