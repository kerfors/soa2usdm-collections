          "row_position": 8
        }
      ]
    },
    {
      "annotation_id": "annot-008",
      "table_id": "table-003",
      "annotation_marker": "8",
      "annotation_type": "footnote",
      "annotation_text": "Footnote not printed in the source (Table 9 prints only footnotes 1-3). Table 9 is the Extended-Visit-Cycle variant of the Main Study, so this most likely corresponds to Table 7 (Main Study) footnote 14: \"For determination of CA-125 progression, at least 2 CA-125 values at least 1 week apart are required for confirmation (Section 6.1).\"",
      "annotation_scope": "activity",
      "referenced_elements": {
        "property_ids": [],
        "column_ids": [],
        "activity_ids": [
          "act-008"
