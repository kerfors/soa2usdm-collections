    {
      "annotation_id": "annot-009",
      "table_id": "table-003",
      "annotation_marker": "9",
      "annotation_type": "footnote",
      "annotation_text": "Footnote not printed in the source (Table 9 prints only footnotes 1-3). Table 9 is the Extended-Visit-Cycle variant of the Main Study, so this most likely corresponds to Table 7 (Main Study) footnote 16: \"Patients will have a 12-lead ECG at Screening, Baseline (predose, within 30 minutes), 2 hours postdose on Day 1(within 30 minutes), Cycle 2/Day 1, (predose, 2 hours postdose, within 30 minutes) and upon study treatment discontinuation. Note that the ECG is to be completed prior to the PK blood draw.\"",
      "annotation_scope": "activity",
      "referenced_elements": {
        "property_ids": [],
        "column_ids": [],
        "activity_ids": [
          "act-009"
        ],
        "cell_references": []
      },
      "marker_locations": [
        {
          "table_number": 3,
