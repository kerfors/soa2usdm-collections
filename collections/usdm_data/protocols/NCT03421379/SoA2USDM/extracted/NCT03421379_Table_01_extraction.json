 "annotations": [
  {
   "annotation_marker": "c1",
   "annotation_type": "footnote",
   "annotation_text": "Admission can be rescheduled if PG level is not 90 to 250 mg/dL on Day 1.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 4
    }
   ]
  },
  {
   "annotation_marker": "c2",
   "annotation_type": "footnote",
   "annotation_text": "Patient may be discharged 6 hours after glucagon administration. A patient may remain inpatient at the CRU at the discretion of the investigator.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 5
    }
   ]
  },
  {
   "annotation_marker": "c3",
   "annotation_type": "footnote",
   "annotation_text": "After screening, medical assessment only performed to include medical review and targeted examination, as appropriate.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 8
    }
   ]
  },
  {
   "annotation_marker": "c4",
   "annotation_type": "footnote",
   "annotation_text": "Height is at screening only. Weight on Day 1 will be collected before the start of the procedure to induce hypoglycemia.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 9
    }
   ]
  },
  {
   "annotation_marker": "c5",
   "annotation_type": "source_note",
   "annotation_text": "Refer to Section 9.5.5.1.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 10
    }
   ]
  },
  {
   "annotation_marker": "c6",
   "annotation_type": "footnote",
   "annotation_text": "Review patients' insulin regimens to confirm acceptability to undergo the procedure to induce hypoglycemia.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 11
    }
   ]
  },
  {
   "annotation_marker": "c7",
   "annotation_type": "footnote",
   "annotation_text": "After completion of all PK sampling, patients will be provided a carbohydrate-rich meal. The investigator will ensure the patient's PG is stable. A prandial insulin dose will be administered if needed.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 12
    }
   ]
  },
  {
   "annotation_marker": "c8",
   "annotation_type": "footnote",
   "annotation_text": "Procedures in Period 2 will occur at approximately the same time as those in Period 1. Insulin infusion is stopped once bedside PG is <60 mg/dL.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 13
    }
   ]
  },
  {
   "annotation_marker": "c9",
   "annotation_type": "footnote",
   "annotation_text": "Samples will be collected during the hypoglycemia induction procedure and post study treatment (up to 120 mins). Bedside PG monitoring will be conducted no more than 10 minutes apart while bedside PG is ≥90 mg/dL and no more than 5 minutes apart when bedside PG is <90 mg/dL.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 14
    }
   ]
  },
  {
   "annotation_marker": "c10",
   "annotation_type": "footnote",
   "annotation_text": "Once bedside PG reaches <60 mg/dL, the insulin infusion is stopped and approximately 5 minutes later study drug is administered. Indicates Time = 0 min.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 15
    }
   ]
  },
  {
   "annotation_marker": "c11",
   "annotation_type": "footnote",
   "annotation_text": "Injection-site assessment for IMG only.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 16
    }
   ]
  },
  {
   "annotation_marker": "c12",
   "annotation_type": "footnote",
   "annotation_text": "Nasal inspection both for IMG and LY900018.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 17
    }
   ]
  },
  {
   "annotation_marker": "c13",
   "annotation_type": "footnote",
   "annotation_text": "Time points may be added for each period if warranted and agreed upon between Lilly and the investigator. Predose time point will be between insulin infusion stop and study treatment.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 18
    }
   ]
  },
  {
   "annotation_marker": "c14",
   "annotation_type": "footnote",
   "annotation_text": "Time points may be added for Period 1 and Period 2 if warranted and agreed upon between Lilly and the investigator. Predose time point will be between insulin infusion stop and study treatment.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 20
    }
   ]
  },
  {
   "annotation_marker": "c15",
   "annotation_type": "source_note",
   "annotation_text": "See Appendix 2, Clinical Laboratory Tests, for details.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 22
    },
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 24
    }
   ]
  },
  {
   "annotation_marker": "c16",
   "annotation_type": "footnote",
   "annotation_text": "See Appendix 2, Clinical Laboratory Tests, for details. Patients do not need to fast for samples at screening or follow-up. At Periods 1 and 2, samples should be collected from patients who have fasted at least 8 hours before any study procedures.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 23
    }
   ]
  },
  {
   "annotation_marker": "c17",
   "annotation_type": "footnote",
   "annotation_text": "Serum pregnancy test will be performed at screening. Urine pregnancy test will be performed at every admission period and follow-up visit if applicable.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 25
    }
   ]
  },
  {
   "annotation_marker": "c18",
   "annotation_type": "footnote",
   "annotation_text": "When needed to confirm postmenopausal status.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 26
    }
   ]
  },
  {
   "annotation_marker": "c19",
   "annotation_type": "footnote",
   "annotation_text": "Additional tests can be done at the discretion of the investigator.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 27
    },
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 28
    }
   ]
  },
  {
   "annotation_marker": "c20",
   "annotation_type": "footnote",
   "annotation_text": "Sampling times are relative to the time of study treatment administration (0 min). Predose time point will be between insulin infusion stop and study treatment.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 29
    }
   ]
  },
  {
   "annotation_marker": "c21",
   "annotation_type": "footnote",
   "annotation_text": "-5 mins = stop insulin infusion. Sampling times are relative to the time of study treatment administration (0 min). Predose time point will be between insulin infusion stop and study treatment.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 30
    }
   ]
  },
  {
   "annotation_marker": "c22",
   "annotation_type": "footnote",
   "annotation_text": "Single sample for pharmacogenetic analysis taken prior to/on Period 1 Day -1.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 31
    }
   ]
  },
  {
   "annotation_marker": "c23",
   "annotation_type": "footnote",
   "annotation_text": "In the event of drug hypersensitivity reactions (immediate or non-immediate), samples will be collected as close to event onset as possible, at event resolution, and 30 days following the event. Patients with TE ADA at follow-up/ED will undergo additional follow-up. Refer to Section 9.7.1 for details.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 32
    }
   ]
  },
  {
   "annotation_marker": "c24",
   "annotation_type": "footnote",
   "annotation_text": "Sampling times are relative to the time of study treatment administration (0 min). Questionnaire will be collected in both LY900018 and IMG treatment groups in both periods.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 35
    }
   ]
  },
  {
   "annotation_marker": "c25",
   "annotation_type": "footnote",
   "annotation_text": "Sampling times are relative to the time of study treatment administration (0 min). During hypoglycemia induction will be when PG ≤75 mg/dL. Predose time point will be between insulin infusion stop and study treatment.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 36
    }
   ]
  },
  {
   "annotation_marker": "a",
   "annotation_type": "footnote",
   "annotation_text": "Samples for immunogenicity, should be collected every 12 weeks (84±7 days) until the titer returns to baseline (ie, returns to within a single 2-fold dilution of the baseline titer) or until 1 year after the last dose of study treatment. A time-matched PK (glucagon) sample may be collected at the follow-up immunogenicity assessment(s) if warranted and agreed upon between both the investigator and sponsor.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "schedule_property",
     "row_position": 1,
     "column_position": 9
    }
   ]
  },
  {
   "annotation_marker": "note1",
   "annotation_type": "footnote",
   "annotation_text": "If multiple procedures take place at the same time point, the following order of the procedure should be used: ECG, vital signs, and venipuncture. Plasma glucose sample should be collected as close as possible of protocol-specified time point.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "schedule_property",
     "row_position": 2
    }
   ]
  }
 ]
