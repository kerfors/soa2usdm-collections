  "unified_annotations": [
    {
      "xannot_id": "xannot-001",
      "annotation_type": "footnote",
      "annotation_text": "Randomization to occur within 4 weeks of the Screening Visit. The Randomization Visit may be a televisit or an in-clinic visit.",
      "display_markers": "T1:a",
      "source_occurrences": [
        {
          "table_num": 1,
          "marker": "a",
          "annotation_id": "annot-001"
