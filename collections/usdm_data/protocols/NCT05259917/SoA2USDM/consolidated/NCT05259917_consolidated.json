      "referenced_xcols": [],
      "cell_references": [],
      "occurrence_count": 1
    },
    {
      "xannot_id": "xannot-005",
      "annotation_type": "footnote",
      "annotation_text": "A televisit can be conducted via a telephone call or via an interactive audio/video system.",
      "display_markers": "T1:e",
      "source_occurrences": [
        {
          "table_num": 1,
          "marker": "e",
          "annotation_id": "annot-005"
        }
