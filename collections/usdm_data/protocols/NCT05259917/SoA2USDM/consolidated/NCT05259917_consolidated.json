      "cell_references": [],
      "occurrence_count": 1
    },
    {
      "xannot_id": "xannot-002",
      "annotation_type": "footnote",
      "annotation_text": "For each of the 3 eligible HAE attacks, a televisit will occur by the next working day after the completion of the patient diary (visit window: +1 week). A televisit must occur before treating the next eligible attack.",
      "display_markers": "T1:b",
      "source_occurrences": [
        {
          "table_num": 1,
          "marker": "b",
          "annotation_id": "annot-002"
        }
      ],
      "referenced_xacts": [
        "xact-002"
