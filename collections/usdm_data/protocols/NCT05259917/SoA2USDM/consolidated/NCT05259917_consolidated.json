      "referenced_xcols": [
        "xcol-003",
        "xcol-004",
        "xcol-005"
      ],
      "cell_references": [],
      "occurrence_count": 1
    },
    {
      "xannot_id": "xannot-003",
      "annotation_type": "footnote",
      "annotation_text": "Once 3 HAE attacks have been treated with IMP, or upon patient ET, the patient should return to the clinic for the final visit as soon as possible within 1 week of completing all patient diary assessments. Whenever possible this visit should be completed prior to starting any new medication or treatment.",
      "display_markers": "T1:c",
      "source_occurrences": [
        {
          "table_num": 1,
          "marker": "c",
          "annotation_id": "annot-003"
        }
