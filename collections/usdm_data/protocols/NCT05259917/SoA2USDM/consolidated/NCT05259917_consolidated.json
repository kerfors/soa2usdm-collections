    },
    {
      "xannot_id": "xannot-006",
      "annotation_type": "footnote",
      "annotation_text": "Consent and assent may be collected through e-consent if allowed through country and site regulations.",
      "display_markers": "T1:f",
      "source_occurrences": [
        {
          "table_num": 1,
