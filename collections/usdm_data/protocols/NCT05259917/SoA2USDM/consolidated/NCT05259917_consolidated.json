    {
      "xannot_id": "xannot-008",
      "annotation_type": "footnote",
      "annotation_text": "Medical history includes any relevant previous and concurrent diseases, HAE disease history including the attack history and corresponding treatment for the past 3 months; therapies and supplements taken within the past 4 weeks; and previous participation in interventional clinical trials in the past 4 weeks.",
      "display_markers": "T1:h",
