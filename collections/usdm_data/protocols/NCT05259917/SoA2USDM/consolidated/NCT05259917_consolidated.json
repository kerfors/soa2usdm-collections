    {
      "xannot_id": "xannot-015",
      "annotation_type": "footnote",
      "annotation_text": "If a patient takes conventional on-demand treatment during the trial, a 48-hour washout period is required prior to the subsequent dosing with IMP.",
      "display_markers": "T1:o",
      "source_occurrences": [
        {
          "table_num": 1,
          "marker": "o",
          "annotation_id": "annot-015"
        }
