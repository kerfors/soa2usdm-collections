    "source_tables": [
      {
        "table_id": "table-001",
        "table_num": 1,
        "table_type": "main_soa",
        "table_title": "Schedule of Activities (SoA) - Protocol J2G-MC-JZPA",
        "table_purpose": "Clinical-pharmacology 2-period crossover food-effect SoA: Screening, in-house Treatment Period Days -1 to 11 (dosing Day 1 and Day 8), Early Discontinuation, and a Follow-Up phone call.",
        "track_label": null,
        "activity_count": 20,
        "column_count": 15,
        "annotation_count": 9,
        "property_hierarchy": [
          {
            "hierarchical_level": 1,
            "property_name": "Study Phase",
            "property_type": "epoch",
            "property_comment": "Top header band carrying study-phase labels: Screening (col 2), the merged 'Treatment Period' span (cols 3-14, i.e. Days -1 through 11), and Follow-Up phone call (col 16). ED (col 15) is a separate white column outside the Treatment Period band and is labelled only in the study-day row. Label cell (col 1) was blank so property_name was synthesized."
          },
          {
            "hierarchical_level": 2,
            "property_name": "Days",
            "property_type": "other",
            "property_comment": "Second header band: the single word 'Days' merged across the treatment columns (cols 3-14), labelling the numeric day columns beneath it. It does not cover Screening (col 2, part of the Screening vertical merge) or ED (col 15). property_name taken from the band text; the col-1 label cell is blank (Procedure cell spans down) so marked synthesized."
          },
          {
            "hierarchical_level": 3,
            "property_name": "Study Day",
            "property_type": "study_day",
            "property_comment": "Timing row carrying study days relative to Day 1 dosing: Screening window '-28 to -2 days prior to Day 1' (col 2), Days -1 and 1..11 (cols 3-14), ED (col 15), and the Follow-Up window 'within 7 to 10 days after last dose' (col 16). Classified study_day for the dominant numeric-day values; the col-1 cell physically holds 'Procedure' (the activity-column header) so property_name 'Study Day' was synthesized."
          }
        ]
      }
    ],
