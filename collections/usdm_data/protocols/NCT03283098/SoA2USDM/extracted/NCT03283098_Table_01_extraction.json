 "annotations": [
  {
   "annotation_marker": "a",
   "annotation_type": "footnote",
   "annotation_text": "If a treated subject withdraws before completion of dosing, the investigator will make every effort to perform Day 29 assessments as close to 2 days after the last dose of investigational product as possible.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "schedule_property",
     "row_position": 1,
     "column_position": 18
    }
   ]
  },
  {
   "annotation_marker": "b",
   "annotation_type": "footnote",
   "annotation_text": "A physical examination will be performed at screening. Abbreviated physical examinations will be performed on day 1 (unless day 1 occurred more than 2 weeks after screening physical examination), Days 15, 29 and 55. Height will be captured once at screening. Weight will be recorded before dialysis.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 6
    },
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 7
    },
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 8
    }
   ]
  },
  {
   "annotation_marker": "c",
   "annotation_type": "footnote",
   "annotation_text": "Common symptoms associated with hemodialysis will be captured at screening. Any worsening of hemodialysis symptoms will be reported as an adverse event.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 9
    }
   ]
  },
  {
   "annotation_marker": "d",
   "annotation_type": "footnote",
   "annotation_text": "Investigational product will be administered by intravenous (IV) injection over approximately 30 seconds into the venous line with dialysis rinse back at the end of the dialysis session.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 10
    }
   ]
  },
  {
   "annotation_marker": "e",
   "annotation_type": "footnote",
   "annotation_text": "Subjects will remain seated for at least 10 minutes prior to measurement of predialysis heart rate and blood pressure. Vital signs will include blood pressure, heart rate, respiratory rate, and oral or ear temperature. Vital signs will be obtained pre-dialysis treatments on scheduled dialysis days, and at ET and on Day 55 (EOS).",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 11
    }
   ]
  },
  {
   "annotation_marker": "f",
   "annotation_type": "footnote",
   "annotation_text": "Subjects will remain supine for at least 5 minutes prior to recording 12-lead electrocardiogram (ECG). Screening 12-lead ECG will be recorded prior to hemodialysis. The Day -2 12-lead ECG will be recorded within 4 hours after hemodialysis rinse back. After the last dose of investigational product on Day 27, 12-lead ECGs will be recorded between 18 and 30 hours (recorded on day 28) post-dose.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 12
    }
   ]
  },
  {
   "annotation_marker": "g",
   "annotation_type": "footnote",
   "annotation_text": "Adverse events will be monitored and recorded from the dose of investigational product (AMG 416) or placebo. Serious adverse events will be monitored and recorded from the time of informed consent through Day 55.",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "activity_name",
     "row_position": 13
    }
   ]
  },
  {
   "annotation_marker": "h",
   "annotation_type": "footnote",
   "annotation_text": "After Day 28, hemodialysis will continue on study days 29, 31, 34, 36, 38, 41, 43, 45, 48, 50, 52 and 55; data collection and study procedures will only occur on hemodialysis days 29, 34, 41, and 55(EOS).",
   "marker_locations": [
    {
     "table_number": 1,
     "location_type": "schedule_property",
     "row_position": 1,
     "column_position": 18
    }
   ]
  },
  {
   "annotation_marker": "i",
   "annotation_type": "footnote",
   "annotation_text": "Demographic information collected at screening includes sex, age, race, and ethnicity.",
