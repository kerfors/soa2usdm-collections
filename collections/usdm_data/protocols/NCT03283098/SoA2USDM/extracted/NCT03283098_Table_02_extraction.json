 "annotations": [
  {
   "annotation_marker": "a",
   "annotation_type": "footnote",
   "annotation_text": "If a treated subject withdraws from study before completion of dosing, the investigator will make every effort to obtain day 29 samples as close to 2 days after the last dose of investigational product as possible.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "schedule_property",
     "row_position": 1,
     "column_position": 18
    }
   ]
  },
  {
   "annotation_marker": "b",
   "annotation_type": "footnote",
   "annotation_text": "If screening albumin, phosphorus, cCa, pregnancy, and iPTH tests occur within 7 days prior to start of IP, then Day -2 lab tests can be waived",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 4,
     "column_position": 3
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 5,
     "column_position": 3
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 6,
     "column_position": 3
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 7,
     "column_position": 3
    },
    {
     "table_number": 2,
     "location_type": "schedule_cell",
     "row_position": 11,
     "column_position": 3
    }
   ]
  },
  {
   "annotation_marker": "c",
   "annotation_type": "footnote",
   "annotation_text": "Blood sample for PT and aPTT will be drawn prior to heparin administration for dialysis. Day 1 hematology and coagulation tests will be performed only if day 1 occurs more than 2 weeks after the screening hematology and coagulation tests.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 2
    }
   ]
  },
  {
   "annotation_marker": "d",
   "annotation_type": "footnote",
   "annotation_text": "Serum samples for albumin and calcium for screening and routine monitoring of predialysis cCa. When albumin is less than 4.0 g/dL, the calcium level will be corrected according to the formula: cCa (mg/dL) = total Ca (mg/dL) + (4 – albumin (g/dL))*0.8. Corrected calcium results will inform dosing/dose withholding at the next hemodialysis treatment.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 4
    },
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 6
    }
   ]
  },
  {
   "annotation_marker": "e",
   "annotation_type": "footnote",
   "annotation_text": "Perform Kt/V or URR assessment at screening unless a qualifying Kt/V or URR measurement from within 4 weeks prior to screening assessments is available.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 13
    }
   ]
  },
  {
   "annotation_marker": "f",
   "annotation_type": "footnote",
   "annotation_text": "Serum samples for anti-drug antibodies will be collected predialysis on days 1, 29, and 55. Any subjects with positive titers for antibodies to AMG 416 may be asked to return to the clinical research unit to provide additional serum samples.",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
     "row_position": 14
    }
   ]
  },
  {
   "annotation_marker": "g",
   "annotation_type": "footnote",
   "annotation_text": "Luteinizing hormone and estradiol levels may additionally be collected if deemed necessary for confirmation of postmenopausal status as described in exclusion criteria section 4.2.4",
   "marker_locations": [
    {
     "table_number": 2,
     "location_type": "activity_name",
