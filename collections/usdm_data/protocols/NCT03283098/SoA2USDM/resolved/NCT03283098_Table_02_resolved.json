      "annotation_marker": "a",
      "annotation_type": "footnote",
      "annotation_text": "If a treated subject withdraws from study before completion of dosing, the investigator will make every effort to obtain day 29 samples as close to 2 days after the last dose of investigational product as possible.",
      "annotation_scope": "column",
